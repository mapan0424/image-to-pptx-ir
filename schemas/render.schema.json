{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mapan0424/image-to-pptx-ir/raw/main/schemas/render.schema.json",
  "title": "Image-to-PPTX Render JSON / PPTX-IR",
  "type": "object",
  "required": ["canvas", "elements", "layerRules", "validationRules"],
  "properties": {
    "version": { "type": "string" },
    "canvas": {
      "type": "object",
      "required": ["width", "height", "unit"],
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "unit": { "const": "px" },
        "pptWidthInches": { "type": "number", "exclusiveMinimum": 0 },
        "pptHeightInches": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "theme": { "type": "object" },
    "layerRules": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "elements": {
      "type": "array",
      "items": { "$ref": "#/$defs/element" }
    },
    "validationRules": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "source": {
      "type": "object",
      "properties": {
        "image": { "type": "string" },
        "sha256": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "boxGeometry": {
      "type": "object",
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "w": { "type": "number", "exclusiveMinimum": 0 },
        "h": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "lineGeometry": {
      "type": "object",
      "required": ["x1", "y1", "x2", "y2"],
      "properties": {
        "x1": { "type": "number" },
        "y1": { "type": "number" },
        "x2": { "type": "number" },
        "y2": { "type": "number" }
      }
    },
    "constraints": {
      "type": "object",
      "properties": {
        "paddingLeft": { "type": "number", "minimum": 0 },
        "paddingRight": { "type": "number", "minimum": 0 },
        "paddingTop": { "type": "number", "minimum": 0 },
        "paddingBottom": { "type": "number", "minimum": 0 },
        "childrenMustStayInside": { "type": "boolean" },
        "clipChildren": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "element": {
      "type": "object",
      "required": ["id", "type", "zIndex"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "enum": ["text", "rect", "roundRect", "line", "connector", "path", "svgIcon", "image", "group"]
        },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "w": { "type": "number", "exclusiveMinimum": 0 },
        "h": { "type": "number", "exclusiveMinimum": 0 },
        "x1": { "type": "number" },
        "y1": { "type": "number" },
        "x2": { "type": "number" },
        "y2": { "type": "number" },
        "zIndex": { "type": "number" },
        "parentId": { "type": "string" },
        "fill": { "type": "string" },
        "stroke": { "type": "string" },
        "strokeWidth": { "type": "number", "minimum": 0 },
        "radius": { "type": "number", "minimum": 0 },
        "dash": { "enum": ["solid", "dash", "dot", "dashDot"] },
        "beginArrow": { "type": "string" },
        "endArrow": { "type": "string" },
        "direction": { "type": "string" },
        "semantic": { "type": "string" },
        "mustNotBeSegmented": { "type": "boolean" },
        "text": { "type": "string" },
        "fontFamily": { "type": "string" },
        "fontSize": { "type": "number", "exclusiveMinimum": 0 },
        "fontWeight": { "type": "number" },
        "color": { "type": "string" },
        "align": { "enum": ["left", "center", "right"] },
        "valign": { "enum": ["top", "middle", "bottom"] },
        "wrap": { "type": "boolean" },
        "fit": { "enum": ["none", "shrink", "resize"] },
        "margin": { "type": "number", "minimum": 0 },
        "library": { "type": "string" },
        "icon": { "type": "string" },
        "path": { "type": "string" },
        "svg": { "type": "string" },
        "d": { "type": "string" },
        "href": { "type": "string" },
        "constraints": { "$ref": "#/$defs/constraints" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/element" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "enum": ["text", "rect", "roundRect", "svgIcon", "image", "group"] } } },
          "then": { "$ref": "#/$defs/boxGeometry" }
        },
        {
          "if": { "properties": { "type": { "enum": ["line", "connector"] } } },
          "then": { "$ref": "#/$defs/lineGeometry" }
        },
        {
          "if": { "properties": { "type": { "const": "text" } } },
          "then": { "required": ["text", "fontFamily", "fontSize", "fontWeight", "color", "wrap", "fit", "margin"] }
        },
        {
          "if": { "properties": { "type": { "const": "connector" } } },
          "then": { "required": ["dash", "beginArrow", "endArrow", "direction", "semantic", "mustNotBeSegmented"] }
        },
        {
          "if": { "properties": { "type": { "const": "group" } } },
          "then": { "required": ["constraints"] }
        },
        {
          "if": { "properties": { "type": { "const": "path" } } },
          "then": { "required": ["d"] }
        },
        {
          "if": { "properties": { "type": { "const": "image" } } },
          "then": { "required": ["href"] }
        }
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
