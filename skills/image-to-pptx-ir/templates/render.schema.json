{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PPTX Render JSON / PPTX-IR",
  "type": "object",
  "required": [
    "canvas",
    "elements",
    "layerRules",
    "validationRules"
  ],
  "properties": {
    "canvas": {
      "type": "object",
      "required": [
        "width",
        "height",
        "unit"
      ],
      "properties": {
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "unit": {
          "type": "string",
          "enum": [
            "px"
          ]
        }
      }
    },
    "theme": {
      "type": "object"
    },
    "layerRules": {
      "type": "object"
    },
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "zIndex"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "rect",
              "roundRect",
              "line",
              "connector",
              "path",
              "svgIcon",
              "image",
              "group"
            ]
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "w": {
            "type": "number"
          },
          "h": {
            "type": "number"
          },
          "x1": {
            "type": "number"
          },
          "y1": {
            "type": "number"
          },
          "x2": {
            "type": "number"
          },
          "y2": {
            "type": "number"
          },
          "zIndex": {
            "type": "number"
          },
          "fill": {
            "type": "string"
          },
          "stroke": {
            "type": "string"
          },
          "strokeWidth": {
            "type": "number"
          },
          "radius": {
            "type": "number"
          },
          "dash": {
            "type": "string",
            "enum": [
              "solid",
              "dash",
              "dot",
              "dashDot"
            ]
          },
          "beginArrow": {
            "type": "string"
          },
          "endArrow": {
            "type": "string"
          },
          "direction": {
            "type": "string"
          },
          "semantic": {
            "type": "string"
          },
          "mustNotBeSegmented": {
            "type": "boolean"
          },
          "text": {
            "type": "string"
          },
          "fontFamily": {
            "type": "string"
          },
          "fontSize": {
            "type": "number"
          },
          "fontWeight": {
            "type": "number"
          },
          "color": {
            "type": "string"
          },
          "wrap": {
            "type": "boolean"
          },
          "fit": {
            "type": "string"
          },
          "margin": {
            "type": "number"
          },
          "library": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "assetId": {
            "type": "string"
          },
          "assetPath": {
            "type": "string"
          },
          "sourceMode": {
            "type": "string",
            "enum": [
              "user_asset",
              "user_asset_directory",
              "source_crop_alpha_matting",
              "gpt_image_reference_edit",
              "icon_library"
            ]
          },
          "visualRole": {
            "type": "string"
          },
          "sourceBBox": {
            "type": "object",
            "required": ["x", "y", "w", "h"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "w": { "type": "number" },
              "h": { "type": "number" }
            },
            "additionalProperties": false
          },
          "alphaBBox": {
            "type": "object",
            "required": ["x", "y", "w", "h"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "w": { "type": "number" },
              "h": { "type": "number" }
            },
            "additionalProperties": false
          },
          "preserveAspectRatio": {
            "type": "boolean"
          },
          "hasAlpha": {
            "type": "boolean"
          },
          "allowLibrarySubstitution": {
            "type": "boolean"
          },
          "allowGenerativeRedraw": {
            "type": "boolean"
          },
          "similarityScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "constraints": {
            "type": "object"
          },
          "children": {
            "type": "array"
          }
        },
        "additionalProperties": true
      }
    },
    "validationRules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
